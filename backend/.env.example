NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

MONGO_URI=mongodb://localhost:27017/app_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=change_me
